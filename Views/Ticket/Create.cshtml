@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Tickets Dashboard";
}
@model TicketSystemProject.Models.ViewModels.TicketCreateViewModel
@{
    ViewData["Title"] = "Create New Ticket";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-4 d-none d-lg-block">
            <div class="h-100 p-5 text-white bg-primary rounded-3 shadow">
                <h2>Bize Yazın!</h2>
                <p class="mt-4">Sorununuzu veya isteğinizi detaylı bir şekilde iletin. Destek ekibimiz en kısa sürede size geri dönüş yapacaktır.</p>
                <ul class="list-unstyled mt-4">
                    <li class="mb-2"><i class="bi bi-check-circle-fill me-2"></i> Doğru öncelik seçin.</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill me-2"></i> Açıklayıcı bir başlık yazın.</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill me-2"></i> Ekran görüntülerini açıklamaya ekleyin.</li>
                </ul>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 fw-bold text-primary">Yeni Destek Talebi</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

              

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold">Konu Başlığı</label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Sorunu kısaca özetleyin..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Priority" class="form-label fw-semibold">Öncelik Durumu</label>
                                <select asp-for="Priority" class="form-select">
                                    <option value="Low">Düşük (Low)</option>
                                    <option value="Medium" selected>Orta (Medium)</option>
                                    <option value="High">Yüksek (High)</option>
                                    <option value="Urgent">Acil (Urgent)</option>
                                </select>
                                <span asp-validation-for="Priority" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold">Detaylı Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Lütfen yaşadığınız sorunu detaylıca anlatın..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-send me-2"></i> Talebi Oluştur
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">İptal</a>
                        </div>
                    </form>
