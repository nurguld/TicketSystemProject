@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Tickets Dashboard";
}

@model List<TicketSystemProject.Models.Ticket>

<div class="dashboard-header d-flex justify-content-between align-items-center p-3 mb-3" style="background-color:#f8f9fa; border-radius:8px;">
    <div class="stats d-flex gap-4">
        <div><strong>Open Tickets:</strong> @Model.Count(t => t.Status == "Open")</div>
        <div><strong>Resolved Tickets:</strong> @Model.Count(t => t.Status == "Closed")</div>
        <div><strong>Avg. Response:</strong> --- </div>
    </div>
    <a asp-controller="Ticket" asp-action="Create" class="btn btn-primary">+ New Ticket</a>
</div>

<div class="ticket-filters d-flex gap-2 mb-4">
    <form method="get" class="d-flex gap-2">
        <input type="text" name="search" placeholder="Search tickets..." class="form-control" value="@Context.Request.Query["search"]" />

        <select name="status" class="form-select">
            @* Tag Helper hatasını önlemek için selected niteliğini boolean olarak verdik *@
            <option value="" selected="@(string.IsNullOrEmpty(Context.Request.Query["status"]))">All Status</option>
            <option value="Open" selected="@(Context.Request.Query["status"] == "Open")">Open</option>
            <option value="Pending" selected="@(Context.Request.Query["status"] == "Pending")">Pending</option>
            <option value="Closed" selected="@(Context.Request.Query["status"] == "Closed")">Closed</option>
        </select>

        <button type="submit" class="btn btn-secondary">Filter</button>
    </form>
</div>

<div class="ticket-cards row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
    @foreach (var ticket in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">
                        @* Dinamik badge rengi *@
                        <span class="badge bg-@(ticket.Status == "Open" ? "success" : ticket.Status == "Pending" ? "warning" : "secondary")">
                            @ticket.Status
                        </span>
                        @ticket.Title
                    </h5>
                    <p class="card-text">
                        @* Null kontrolü parantez içine alındı *@
                        <small class="text-muted">Created by: @(ticket.User?.UserName ?? "Unknown")</small>
                    </p>
                    <p class="card-text">
                        <small class="text-muted">Created: @ticket.CreatedDate.ToString("yyyy-MM-dd HH:mm")</small>
                    </p>
                    <p class="card-text">
                        @* Açıklama kısaltma mantığı *@
                        @(ticket.Description != null ? (ticket.Description.Length > 50 ? ticket.Description.Substring(0, 50) + "..." : ticket.Description) : "")
                    </p>
                </div>
                <div class="card-footer d-flex justify-content-between">
                    <a asp-controller="Ticket" asp-action="Details" asp-route-id="@ticket.TicketId" class="btn btn-sm btn-info">View</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Tickets" asp-action="Edit" asp-route-id="@ticket.TicketId" class="btn btn-sm btn-warning">Edit</a>

                        <form asp-controller="Tickets" asp-action="Delete" asp-route-id="@ticket.TicketId" method="post" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this ticket?');">Delete</button>
                        </form>
                    }

                </div>
            </div>
        </div>
    }
</div>